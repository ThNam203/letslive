# Backend API (used for REST and WS URLs)
NEXT_PUBLIC_BACKEND_PROTOCOL=http
NEXT_PUBLIC_BACKEND_IP_ADDRESS=localhost
NEXT_PUBLIC_BACKEND_PORT=8000
NEXT_PUBLIC_BACKEND_WS_PROTOCOL=ws

# Environment: development | production
NEXT_PUBLIC_ENVIRONMENT=development

# Cloudflare Turnstile (captcha) – get keys from Cloudflare dashboard
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Sentry (optional – for source maps upload in next.config.js)
# SENTRY_AUTH_TOKEN=

# Build/runtime (optional – CI sets this; APP_ENV used by Sentry)
# APP_ENV=development
# CI=
